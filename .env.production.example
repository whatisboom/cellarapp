# ── Database ──────────────────────────────────────────
# These are used by both the Postgres container and the app.
POSTGRES_USER=beercellar
POSTGRES_PASSWORD=CHANGE_ME_use_a_strong_password

# ── Session ───────────────────────────────────────────
SESSION_SECRET=CHANGE_ME_at_least_32_random_characters

# ── Untappd OAuth ─────────────────────────────────────
UNTAPPD_CLIENT_ID=your_untappd_client_id
UNTAPPD_CLIENT_SECRET=your_untappd_client_secret
UNTAPPD_CALLBACK_URL=https://yourdomain.com/auth/oauth/untappd

# ── Client-side env vars ──────────────────────────────
VITE_UNTAPPD_CLIENT_ID=your_untappd_client_id
VITE_UNTAPPD_CALLBACK_URL=https://yourdomain.com/auth/oauth/untappd

# ── Optional ──────────────────────────────────────────
# APP_PORT=3000  # Change if 3000 is taken on the host
